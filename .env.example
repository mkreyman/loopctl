# loopctl environment variables
# Copy to /opt/loopctl/.env and fill in actual values

# Database connection (standard user with RLS enforced)
DATABASE_URL=ecto://loopctl_app:loopctl_app_password@localhost/loopctl_prod

# Database connection for admin operations (BYPASSRLS role)
ADMIN_DATABASE_URL=ecto://loopctl_admin:loopctl_admin_password@localhost/loopctl_prod

# Phoenix secret key base (generate: mix phx.gen.secret)
SECRET_KEY_BASE=REPLACE_WITH_MIX_PHX_GEN_SECRET_OUTPUT

# Cloak encryption key for secrets at rest (generate: :crypto.strong_rand_bytes(32) |> Base.encode64())
CLOAK_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# Application hostname
PHX_HOST=loopctl.local

# Application port
PORT=4000

# Enable the Phoenix server
PHX_SERVER=true

# Optional: database pool sizes
POOL_SIZE=10
ADMIN_POOL_SIZE=3

# Optional: DNS cluster query for distributed Erlang
# DNS_CLUSTER_QUERY=

# Optional: enable IPv6 for database connections
# ECTO_IPV6=true
